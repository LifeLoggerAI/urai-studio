{
  "name": "urai-studio-monorepo",
  "private": true,
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20 <21",
    "pnpm": "9.7.0"
  },
  "scripts": {
    "build": "pnpm --filter studio build",
    "dev": "pnpm --filter studio dev",
    "lint": "pnpm --filter studio lint",
    "typecheck": "pnpm --filter studio typecheck",
    "test": "pnpm --filter studio test",
    "smoke": "HOST=${HOST:-http://127.0.0.1:3000} bash scripts/smoke.sh",
    "studio:smoke": "node scripts/studio-smoke-v1.js",
    "done-done:guard": "node scripts/done-done-guard.mjs",
    "audit": "pnpm done-done:guard && pnpm lint && pnpm typecheck && pnpm test && pnpm studio:smoke",
    "release:check": "pnpm run audit && pnpm build",
    "emulators": "firebase emulators:start",
    "seed:demo": "pnpm exec ts-node scripts/seed_demo_job.ts",
    "studio:clean": "rm -rf node_modules apps/studio/node_modules packages/*/node_modules apps/studio/.next .next",
    "studio:reinstall": "corepack enable && corepack prepare pnpm@9.7.0 --activate && pnpm install --no-frozen-lockfile",
    "studio:doctor": "bash scripts/firebase-studio-doctor.sh",
    "studio:repair": "bash scripts/firebase-studio-repair.sh",
    "studio:preview": "pnpm -C apps/studio dev -- --hostname 0.0.0.0 --port ${PORT:-3000}",
    "firebase:preview": "pnpm run studio:preview",
    "firebase:emulators": "npx firebase emulators:start --only auth,firestore,storage,functions,hosting"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  }
}
